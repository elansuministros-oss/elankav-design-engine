{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elankav.com/schemas/DesignProfile.schema.json",
  "title": "DesignProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "category",
    "supportedProjectTypes",
    "materials",
    "fixings",
    "lighting",
    "environments",
    "compositionRules",
    "restrictions",
    "allowedOutputs",
    "qaRules"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "signage",
        "facades",
        "interiors",
        "instagrammable",
        "vehicles",
        "branding"
      ]
    },
    "supportedProjectTypes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "baseDimensions": {
      "type": ["object", "null"]
    },
    "allowedDimensionRange": {
      "type": ["object", "null"]
    },
    "materials": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "fixings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lighting": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "environments": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compositionRules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "restrictions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowedOutputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "qaRules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
