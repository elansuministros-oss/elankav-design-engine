{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elankav.com/schemas/QaResult.schema.json",
  "title": "QaResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approved",
    "checks",
    "warnings",
    "errors"
  ],
  "properties": {
    "approved": {
      "type": "boolean"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "passed"],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "passed": {
            "type": "boolean"
          },
          "message": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
